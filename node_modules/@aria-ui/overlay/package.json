      "import": "./dist/elements.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@floating-ui/dom": "^1.7.3",
    "@floating-ui/utils": "^0.2.10",
    "@zag-js/dom-query": "^1.21.6",
    "@aria-ui/core": "^0.0.22"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup"
  },
  "module": "dist/index.js",
  "types": "dist/index.d.ts"
