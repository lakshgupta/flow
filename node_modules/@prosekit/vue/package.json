{
  "name": "@prosekit/vue",
  "type": "module",
  "version": "0.6.8",
  "private": false,
  "description": "Vue components and utilities for ProseKit",
  "author": {
    "name": "ocavue",
    "email": "ocavue@gmail.com"
  },
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/prosekit/prosekit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prosekit/prosekit.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/prosekit/prosekit/issues"
  },
  "keywords": [
    "ProseMirror"
  ],
  "sideEffects": false,
  "main": "./dist/prosekit-vue.js",
  "module": "./dist/prosekit-vue.js",
  "exports": {
    ".": {
      "types": "./dist/prosekit-vue.d.ts",
      "default": "./dist/prosekit-vue.js"
    },
    "./autocomplete": {
      "types": "./dist/prosekit-vue-autocomplete.d.ts",
      "default": "./dist/prosekit-vue-autocomplete.js"
    },
    "./block-handle": {
      "types": "./dist/prosekit-vue-block-handle.d.ts",
      "default": "./dist/prosekit-vue-block-handle.js"
    },
    "./drop-indicator": {
      "types": "./dist/prosekit-vue-drop-indicator.d.ts",
      "default": "./dist/prosekit-vue-drop-indicator.js"
    },
    "./inline-popover": {
      "types": "./dist/prosekit-vue-inline-popover.d.ts",
      "default": "./dist/prosekit-vue-inline-popover.js"
    },
    "./popover": {
      "types": "./dist/prosekit-vue-popover.d.ts",
      "default": "./dist/prosekit-vue-popover.js"
    },
    "./resizable": {
      "types": "./dist/prosekit-vue-resizable.d.ts",
      "default": "./dist/prosekit-vue-resizable.js"
    },
    "./table-handle": {
      "types": "./dist/prosekit-vue-table-handle.d.ts",
      "default": "./dist/prosekit-vue-table-handle.js"
    },
    "./tooltip": {
      "types": "./dist/prosekit-vue-tooltip.d.ts",
      "default": "./dist/prosekit-vue-tooltip.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@prosemirror-adapter/core": "^0.5.2",
    "@prosemirror-adapter/vue": "^0.5.2",
    "@prosekit/web": "^0.7.13",
    "@prosekit/pm": "^0.1.15",
    "@prosekit/core": "^0.11.0"
  },
  "peerDependencies": {
    "vue": ">= 3.0.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "tsdown": "^0.21.4",
    "typescript": "~5.9.3",
    "vitest": "^4.1.1",
    "vue": "^3.5.30",
    "@prosekit/config-ts": "0.0.0",
    "@prosekit/config-vitest": "0.0.0",
    "@prosekit/config-tsdown": "0.0.0"
  },
  "publishConfig": {
    "dev": {}
  },
  "dev": {
    "entry": {
      "prosekit-vue": "./src/index.ts",
      "prosekit-vue-autocomplete": "./src/components/autocomplete/index.gen.ts",
      "prosekit-vue-block-handle": "./src/components/block-handle/index.gen.ts",
      "prosekit-vue-drop-indicator": "./src/components/drop-indicator/index.gen.ts",
      "prosekit-vue-inline-popover": "./src/components/inline-popover/index.gen.ts",
      "prosekit-vue-popover": "./src/components/popover/index.gen.ts",
      "prosekit-vue-resizable": "./src/components/resizable/index.gen.ts",
      "prosekit-vue-table-handle": "./src/components/table-handle/index.gen.ts",
      "prosekit-vue-tooltip": "./src/components/tooltip/index.gen.ts"
    }
  },
  "scripts": {
    "build:tsc": "tsc -b tsconfig.json",
    "build:tsdown": "tsdown"
  },
  "types": "./dist/prosekit-vue.d.ts",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/prosekit-vue.d.ts"
      ],
      "autocomplete": [
        "./dist/prosekit-vue-autocomplete.d.ts"
      ],
      "block-handle": [
        "./dist/prosekit-vue-block-handle.d.ts"
      ],
      "drop-indicator": [
        "./dist/prosekit-vue-drop-indicator.d.ts"
      ],
      "inline-popover": [
        "./dist/prosekit-vue-inline-popover.d.ts"
      ],
      "popover": [
        "./dist/prosekit-vue-popover.d.ts"
      ],
      "resizable": [
        "./dist/prosekit-vue-resizable.d.ts"
      ],
      "table-handle": [
        "./dist/prosekit-vue-table-handle.d.ts"
      ],
      "tooltip": [
        "./dist/prosekit-vue-tooltip.d.ts"
      ]
    }
  }
}