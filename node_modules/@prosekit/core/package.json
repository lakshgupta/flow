{
  "name": "@prosekit/core",
  "type": "module",
  "version": "0.11.0",
  "private": false,
  "description": "Core features for ProseKit",
  "author": {
    "name": "ocavue",
    "email": "ocavue@gmail.com"
  },
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/prosekit/prosekit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prosekit/prosekit.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/prosekit/prosekit/issues"
  },
  "keywords": [
    "ProseMirror"
  ],
  "sideEffects": false,
  "main": "./dist/prosekit-core.js",
  "module": "./dist/prosekit-core.js",
  "exports": {
    ".": {
      "types": "./dist/prosekit-core.d.ts",
      "default": "./dist/prosekit-core.js"
    },
    "./test": {
      "types": "./dist/prosekit-core-test.d.ts",
      "default": "./dist/prosekit-core-test.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@ocavue/utils": "^1.6.0",
    "clsx": "^2.1.1",
    "orderedmap": "^2.1.1",
    "prosemirror-splittable": "^0.1.1",
    "type-fest": "^5.5.0",
    "@prosekit/pm": "^0.1.15"
  },
  "devDependencies": {
    "diffable-html-snapshot": "^0.2.0",
    "tsdown": "^0.21.4",
    "typescript": "~5.9.3",
    "vitest": "^4.1.1",
    "vitest-browser-commands": "^0.2.0",
    "@prosekit/config-tsdown": "0.0.0",
    "@prosekit/config-ts": "0.0.0",
    "@prosekit/config-vitest": "0.0.0"
  },
  "publishConfig": {
    "dev": {}
  },
  "dev": {
    "entry": {
      "prosekit-core": "./src/index.ts",
      "prosekit-core-test": "./src/test/index.ts"
    }
  },
  "scripts": {
    "build:tsc": "tsc -b tsconfig.json",
    "build:tsdown": "tsdown"
  },
  "types": "./dist/prosekit-core.d.ts",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/prosekit-core.d.ts"
      ],
      "test": [
        "./dist/prosekit-core-test.d.ts"
      ]
    }
  }
}