{
  "name": "@prosekit/react",
  "type": "module",
  "version": "0.6.9",
  "private": false,
  "description": "React components and utilities for ProseKit",
  "author": {
    "name": "ocavue",
    "email": "ocavue@gmail.com"
  },
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/prosekit/prosekit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prosekit/prosekit.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/prosekit/prosekit/issues"
  },
  "keywords": [
    "ProseMirror"
  ],
  "sideEffects": false,
  "main": "./dist/prosekit-react.js",
  "module": "./dist/prosekit-react.js",
  "exports": {
    ".": {
      "types": "./dist/prosekit-react.d.ts",
      "default": "./dist/prosekit-react.js"
    },
    "./autocomplete": {
      "types": "./dist/prosekit-react-autocomplete.d.ts",
      "default": "./dist/prosekit-react-autocomplete.js"
    },
    "./block-handle": {
      "types": "./dist/prosekit-react-block-handle.d.ts",
      "default": "./dist/prosekit-react-block-handle.js"
    },
    "./drop-indicator": {
      "types": "./dist/prosekit-react-drop-indicator.d.ts",
      "default": "./dist/prosekit-react-drop-indicator.js"
    },
    "./inline-popover": {
      "types": "./dist/prosekit-react-inline-popover.d.ts",
      "default": "./dist/prosekit-react-inline-popover.js"
    },
    "./popover": {
      "types": "./dist/prosekit-react-popover.d.ts",
      "default": "./dist/prosekit-react-popover.js"
    },
    "./resizable": {
      "types": "./dist/prosekit-react-resizable.d.ts",
      "default": "./dist/prosekit-react-resizable.js"
    },
    "./table-handle": {
      "types": "./dist/prosekit-react-table-handle.d.ts",
      "default": "./dist/prosekit-react-table-handle.js"
    },
    "./tooltip": {
      "types": "./dist/prosekit-react-tooltip.d.ts",
      "default": "./dist/prosekit-react-tooltip.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@prosemirror-adapter/core": "^0.5.2",
    "@prosemirror-adapter/react": "^0.5.2",
    "@prosekit/core": "^0.11.0",
    "@prosekit/web": "^0.7.13",
    "@prosekit/pm": "^0.1.15"
  },
  "peerDependencies": {
    "react": ">= 18.2.0",
    "react-dom": ">= 18.2.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsdown": "^0.21.4",
    "typescript": "~5.9.3",
    "@prosekit/config-ts": "0.0.0",
    "@prosekit/config-tsdown": "0.0.0",
    "@prosekit/config-vitest": "0.0.0"
  },
  "publishConfig": {
    "dev": {}
  },
  "dev": {
    "entry": {
      "prosekit-react": "./src/index.ts",
      "prosekit-react-autocomplete": "./src/components/autocomplete/index.gen.ts",
      "prosekit-react-block-handle": "./src/components/block-handle/index.gen.ts",
      "prosekit-react-drop-indicator": "./src/components/drop-indicator/index.gen.ts",
      "prosekit-react-inline-popover": "./src/components/inline-popover/index.gen.ts",
      "prosekit-react-popover": "./src/components/popover/index.gen.ts",
      "prosekit-react-resizable": "./src/components/resizable/index.gen.ts",
      "prosekit-react-table-handle": "./src/components/table-handle/index.gen.ts",
      "prosekit-react-tooltip": "./src/components/tooltip/index.gen.ts"
    }
  },
  "scripts": {
    "build:tsc": "tsc -b tsconfig.json",
    "build:tsdown": "tsdown"
  },
  "types": "./dist/prosekit-react.d.ts",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/prosekit-react.d.ts"
      ],
      "autocomplete": [
        "./dist/prosekit-react-autocomplete.d.ts"
      ],
      "block-handle": [
        "./dist/prosekit-react-block-handle.d.ts"
      ],
      "drop-indicator": [
        "./dist/prosekit-react-drop-indicator.d.ts"
      ],
      "inline-popover": [
        "./dist/prosekit-react-inline-popover.d.ts"
      ],
      "popover": [
        "./dist/prosekit-react-popover.d.ts"
      ],
      "resizable": [
        "./dist/prosekit-react-resizable.d.ts"
      ],
      "table-handle": [
        "./dist/prosekit-react-table-handle.d.ts"
      ],
      "tooltip": [
        "./dist/prosekit-react-tooltip.d.ts"
      ]
    }
  }
}