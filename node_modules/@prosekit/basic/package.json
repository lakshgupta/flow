{
  "name": "@prosekit/basic",
  "type": "module",
  "version": "0.8.0",
  "private": false,
  "description": "A quick starter for ProseKit",
  "author": {
    "name": "ocavue",
    "email": "ocavue@gmail.com"
  },
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/prosekit/prosekit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prosekit/prosekit.git",
    "directory": "packages/basic"
  },
  "bugs": {
    "url": "https://github.com/prosekit/prosekit/issues"
  },
  "keywords": [
    "ProseMirror"
  ],
  "sideEffects": false,
  "main": "./dist/prosekit-basic.js",
  "module": "./dist/prosekit-basic.js",
  "exports": {
    ".": {
      "types": "./dist/prosekit-basic.d.ts",
      "default": "./dist/prosekit-basic.js"
    },
    "./style.css": {
      "default": "./dist/style.css"
    },
    "./typography.css": {
      "default": "./dist/typography.css"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@prosekit/core": "^0.11.0",
    "@prosekit/extensions": "^0.15.0",
    "@prosekit/pm": "^0.1.15"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "happy-dom": "^20.8.7",
    "jsdom": "^29.0.1",
    "sass": "^1.98.0",
    "tsdown": "^0.21.4",
    "typescript": "~5.9.3",
    "vitest": "^4.1.1",
    "@prosekit/config-tsdown": "0.0.0",
    "@prosekit/config-ts": "0.0.0",
    "@prosekit/config-vitest": "0.0.0"
  },
  "publishConfig": {
    "dev": {}
  },
  "dev": {
    "entry": {
      "prosekit-basic": "./src/index.ts",
      "style": "./src/style.css",
      "typography": "./src/typography.css"
    }
  },
  "scripts": {
    "dev": "sass --watch --no-source-map ./src/typography.scss ./src/typography.gen.css",
    "gen": "sass --no-source-map ./src/typography.scss ./src/typography.gen.css",
    "build:tsc": "tsc -b tsconfig.json",
    "build:tsdown": "tsdown"
  },
  "types": "./dist/prosekit-basic.d.ts",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/prosekit-basic.d.ts"
      ]
    }
  }
}